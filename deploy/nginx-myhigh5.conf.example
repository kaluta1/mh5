# Example nginx config for myhigh5.com on a VPS.
# Install: sudo cp deploy/nginx-myhigh5.conf.example /etc/nginx/sites-available/myhigh5.com
#          sudo ln -sf /etc/nginx/sites-available/myhigh5.com /etc/nginx/sites-enabled/
#          sudo nginx -t && sudo systemctl reload nginx
#
# Requires:
#   - Next.js: 127.0.0.1:3000  (cd frontend && npm run build && npm run start:vps)
#   - FastAPI: 127.0.0.1:8000  (uvicorn on port 8000)
#
# VPS media: set STORAGE_TYPE=local and LOCAL_STORAGE_PATH=/app/storage (Docker)
# or /var/lib/myhigh5/media (bare metal). See backend/.env.vps.example.

server {
    listen 80;
    listen [::]:80;
    server_name myhigh5.com www.myhigh5.com;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name myhigh5.com www.myhigh5.com;

    # ssl_certificate     /etc/letsencrypt/live/myhigh5.com/fullchain.pem;
    # ssl_certificate_key /etc/letsencrypt/live/myhigh5.com/privkey.pem;

    client_max_body_size 64M;

    # FastAPI — must come before location /
    location /api/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_read_timeout 120s;
    }

    # Optional: media files served by backend
    location /media/ {
        proxy_pass http://127.0.0.1:8000;
        proxy_set_header Host $host;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # IMPORTANT: /s/f and /s/c must hit Next.js (OG preview HTML), not the API.
    # Do NOT add a separate location /s/ { proxy_pass ...8000; } block.

    # Everything else → Next.js (includes /s/f/24 share links)
    location / {
        proxy_pass http://127.0.0.1:3000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }
}
