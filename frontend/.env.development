# Full site in local dev. Omit or set true to preview the maintenance page.
IS_MAINTENANCE_MODE=true

# Used by `next dev` when NEXT_PUBLIC_API_URL is not set in `.env.local`.
# Match `uvicorn` port (e.g. `uvicorn main:app --port 8001`). On a VPS use http://YOUR_IP:8001.
NEXT_PUBLIC_API_URL=http://localhost:8001

# Same-host fix when NEXT_PUBLIC_* still says localhost but you opened the UI via VPS IP/domain (optional override).
# NEXT_PUBLIC_BACKEND_PUBLIC_PORT=8001

# Optional: AI UI translation (OpenAI-compatible Chat Completions). Set in `.env.local` (not committed).
# OPENAI_API_KEY=sk-...
# Optional aliases: CURSOR_API_KEY=... or AI_API_KEY=... (same use as OPENAI_API_KEY)
# AI_API_BASE_URL=https://api.openai.com/v1
# AI_TRANSLATION_MODEL=gpt-4o-mini
CURSOR_API_KEY=crsr_8cced7dbd01f51b958646d22528928eb505ca38b57849d6dddb770ecb0783a3d
