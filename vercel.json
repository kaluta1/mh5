{
  "version": 2,
  "buildCommand": "cd frontend && npm install && npm run build",
  "outputDirectory": "frontend/.next",
  "framework": "nextjs",
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/next"
    },
    {
      "src": "backend/api/index.py",
      "use": "@vercel/python",
      "config": {
        "maxLambdaSize": "50mb"
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.py"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ],
  "env": {
    "PYTHON_VERSION": "3.11"
  },
  "functions": {
    "backend/api/index.py": {
      "maxDuration": 60
    }
  },
  "crons": [
    {
      "path": "/api/cron/payments",
      "schedule": "*/2 * * * *"
    },
    {
      "path": "/api/cron/contest-status",
      "schedule": "*/5 * * * *"
    }
  ],
  "ignore": [
    "backend/migrations/**",
    "backend/scripts/**",
    "backend/*.py",
    "backend/*.md",
    "backend/*.sql",
    "backend/*.txt",
    "backend/Dockerfile",
    "backend/docker-compose.yml"
  ]
}
