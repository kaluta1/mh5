# Database Configuration
DATABASE_URL=postgresql://user:password@localhost:5432/myhigh5

# Security (SECRET_KEY should be a strong random string, max 64 chars recommended)
SECRET_KEY=your-secret-key-here-max-64-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# CORS Origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://myhigh5.vercel.app,https://mh5-rx4z.onrender.com

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./media
S3_BUCKET_NAME=
S3_REGION=

# Environment
ENVIRONMENT=production
