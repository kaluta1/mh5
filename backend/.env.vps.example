# VPS production — copy to backend/.env (no AWS required)
#
# Profile photos & uploads use local disk + API route:
#   GET /api/v1/media/file/{user_id}/{filename}

# --- Storage (local disk) ---
STORAGE_TYPE=local
# Docker (docker-compose.yml mounts media_data → /app/storage):
LOCAL_STORAGE_PATH=/app/storage
# Bare metal (no Docker) — use a path on the VPS that survives reboots:
# LOCAL_STORAGE_PATH=/var/lib/myhigh5/media

# Public API origin (must match how browsers reach FastAPI)
BACKEND_PUBLIC_URL=https://api.myhigh5.com
# If API is only on myhigh5.com/api (no api subdomain), use:
# BACKEND_PUBLIC_URL=https://myhigh5.com

FRONTEND_URL=https://myhigh5.com

# --- Do NOT set these on VPS unless you switch back to S3 ---
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_REGION=

# --- App ---
DATABASE_URL=postgresql://user:password@localhost:5432/myhigh5
SECRET_KEY=change-me-long-random-string
BACKEND_CORS_ORIGINS=https://myhigh5.com,https://www.myhigh5.com
